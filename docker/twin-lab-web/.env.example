# ─── Encryption ────────────────────────────────────────────────────
# AES-256-GCM Master-Key. Aus Passwort-Manager (Production-Key).
TWIN_LAB_ENCRYPTION_KEY=

# ─── Session ───────────────────────────────────────────────────────
# iron-session Cookie-Signing-Secret. Generieren mit:
#   openssl rand -base64 48
TWIN_LAB_SESSION_SECRET=

# Cookie-Attribute fürs Cross-Subdomain-Setup (Web auf app.*, Runtime
# auf runtime.*). Domain mit führendem Punkt, damit Browser ihn an
# beide Subdomains sendet. Secure: true erzwingt HTTPS-only.
SESSION_COOKIE_DOMAIN=.twin.harwayexperience.com
SESSION_COOKIE_SECURE=true

# ─── Deployment-Label fürs Frontend ────────────────────────────────
# Wird in den AppFooter inlined (NEXT_PUBLIC_*, also Client-Bundle).
# Production: "production". Lokal ungesetzt → Default "läuft lokal".
NEXT_PUBLIC_DEPLOYMENT_LABEL=production

# ─── Bridge ────────────────────────────────────────────────────────
# Default-URL fürs Onboarding — wird beim Twin-Profil-Insert genutzt.
TWIN_LAB_DEFAULT_BRIDGE_URL=https://bridge.twin.harwayexperience.com

# Allowlist-Token für POST /twins/register an die Production-Bridge.
# Wert findet sich in /docker/twin-lab-bridge/.env auf demselben VPS.
BRIDGE_REGISTER_TOKEN=

# ─── Provider ──────────────────────────────────────────────────────
# Default-Provider (wird vom Onboarding genutzt, falls User nichts wählt).
# Per-Twin-API-Key wird verschlüsselt in DB gespeichert.
# ACTIVE_PROVIDER=anthropic
