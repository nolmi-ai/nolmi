# ─── NOLMI-STACK .env (Vorlage) ───────────────────────────────────────────────
#
# Kopiere zu `.env` neben der docker-compose.yml (/docker/nolmi/) und fülle die
# Werte. NICHT committen.
#
# ⚠ B2 = MECHANIK-VALIDIERUNG: Wegwerf-Secrets + ACME_RESOLVER=le-staging.
#   Der Stack fährt mit LEEREN Volumes hoch, nur um Compose/Traefik/BasicAuth/
#   Container-Hop zu beweisen — keine echten Daten.
#
# ⚠ B4 = ECHTER CUT-OVER: NOLMI_ENCRYPTION_KEY MUSS der Key vom alten VPS sein
#   (Bedingung A — verschlüsselt per-Twin-API-Keys + OAuth-Tokens in der
#   migrierten twin.db; ein neuer Key macht alle Secrets unbrauchbar) UND
#   ACME_RESOLVER=le (Produktions-Zertifikate statt Staging).

# ─── Secrets ───────────────────────────────────────────────────────────────
# B2: openssl rand -hex 32 (Wegwerf). B4: ECHTER Key vom alten VPS übernehmen.
NOLMI_ENCRYPTION_KEY=<placeholder-32-byte-hex>
# Session-Secret: in JEDEM Fall neu (Cookie-Domain wechselt zu .nolmi.ai).
NOLMI_SESSION_SECRET=<placeholder-random-secret>
# Bridge-Register-Token: neu (openssl rand -hex 32). Steuert nur ZUKÜNFTIGE
# Twin-Registrierungen (POST /twins/register); die 3 Bestands-Twins kommen mit
# der migrierten bridge.db, re-registrieren NICHT (S3-Klarstellung).
BRIDGE_REGISTER_TOKEN=<placeholder-32-byte-hex>

# ─── Cookie / Domain ─────────────────────────────────────────────────────────
SESSION_COOKIE_DOMAIN=.nolmi.ai
SESSION_COOKIE_SECURE=true

# ─── Provider ──────────────────────────────────────────────────────────────
ACTIVE_PROVIDER=anthropic
# Hinweis: per-Twin-API-Keys liegen verschlüsselt in der DB (kein ENV nötig).
# Kein ANTHROPIC_API_KEY hier — Twins tragen ihre Keys selbst (BYOK).

# ─── Traefik / ACME ──────────────────────────────────────────────────────────
# B2: le-staging (Staging-CA, kein Rate-Limit-Risiko beim Mechanik-Test).
# B4: le (Produktions-CA). Muss als Resolver in der Traefik-Config existieren.
ACME_RESOLVER=le-staging

# ─── Telegram / Webhook ──────────────────────────────────────────────────────
# Production-Default ist Webhook-Modus (Polling aus). Im Webhook-Modus ist
# RUNTIME_PUBLIC_URL PFLICHT — fehlt sie, crash-loopt die Runtime beim Boot
# (Webhook-Registrierung braucht eine öffentliche URL). Echter Wert, kein
# Wegwerf — bleibt in B4. Nur wenn TELEGRAM_USE_POLLING=true darf sie leer
# bleiben. (B2-Befund 2, PHASE-4-VPS-STRATEGY §7.)
TELEGRAM_USE_POLLING=false
RUNTIME_PUBLIC_URL=https://runtime.nolmi.ai
