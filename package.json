{
  "name": "twin-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Lab-Setup für persönliche AI-Twins mit A2A-Kommunikation",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:init": "pnpm --filter @twin-lab/runtime db:init",
    "twin:mcp-add": "pnpm --filter @twin-lab/runtime twin:mcp-add",
    "twin:mcp-list": "pnpm --filter @twin-lab/runtime twin:mcp-list",
    "twin:mcp-refresh": "pnpm --filter @twin-lab/runtime twin:mcp-refresh",
    "twin:mcp-remove": "pnpm --filter @twin-lab/runtime twin:mcp-remove",
    "twin:facts-list": "pnpm --filter @twin-lab/runtime twin:facts-list",
    "twin:facts-add": "pnpm --filter @twin-lab/runtime twin:facts-add",
    "twin:facts-remove": "pnpm --filter @twin-lab/runtime twin:facts-remove",
    "twin:facts-import": "pnpm --filter @twin-lab/runtime twin:facts-import",
    "bridge:dev": "pnpm --filter @twin-lab/bridge dev",
    "bridge:db:init": "pnpm --filter @twin-lab/bridge db:init",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
