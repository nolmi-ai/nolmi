{
  "name": "twin-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Lab-Setup für persönliche AI-Twins mit A2A-Kommunikation",
  "license": "Apache-2.0",
  "author": {
    "name": "Markus Baier",
    "email": "markus.baier@harwayexperience.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/markusbaier/twin-lab.git"
  },
  "bugs": {
    "url": "https://github.com/markusbaier/twin-lab/issues"
  },
  "homepage": "https://github.com/markusbaier/twin-lab#readme",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:init": "pnpm --filter @nolmi/runtime db:init",
    "twin:mcp-add": "pnpm --filter @nolmi/runtime twin:mcp-add",
    "twin:mcp-list": "pnpm --filter @nolmi/runtime twin:mcp-list",
    "twin:mcp-refresh": "pnpm --filter @nolmi/runtime twin:mcp-refresh",
    "twin:mcp-remove": "pnpm --filter @nolmi/runtime twin:mcp-remove",
    "twin:facts-list": "pnpm --filter @nolmi/runtime twin:facts-list",
    "twin:facts-add": "pnpm --filter @nolmi/runtime twin:facts-add",
    "twin:facts-remove": "pnpm --filter @nolmi/runtime twin:facts-remove",
    "twin:facts-import": "pnpm --filter @nolmi/runtime twin:facts-import",
    "twin:facts-extract": "pnpm --filter @nolmi/runtime twin:facts-extract",
    "twin:diary-add": "pnpm --filter @nolmi/runtime twin:diary-add",
    "twin:diary-list": "pnpm --filter @nolmi/runtime twin:diary-list",
    "twin:memory-embed-all": "pnpm --filter @nolmi/runtime twin:memory-embed-all",
    "twin:oauth-login": "pnpm --filter @nolmi/runtime twin:oauth-login",
    "twin:oauth-phase1-smoke": "pnpm --filter @nolmi/runtime twin:oauth-phase1-smoke",
    "twin:oauth-phase2-smoke": "pnpm --filter @nolmi/runtime twin:oauth-phase2-smoke",
    "bridge:dev": "pnpm --filter @nolmi/bridge dev",
    "bridge:db:init": "pnpm --filter @nolmi/bridge db:init",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
