# ─── Rebrand Twin-Lab → Nolmi (Tag 31, Mai 2026) ────────────────────────────
# Env-Var-Namen wurden von "TWIN_LAB_*" auf "NOLMI_*" umgestellt. Das Aliasing-
# Fenster läuft 6–12 Monate: die alten "TWIN_LAB_*"-Namen werden weiterhin
# akzeptiert, lösen aber im Runtime eine Deprecation-Warning aus. Spätestens
# Mai 2027 fällt der Fallback weg — Production-Setups bitte zeitnah auf
# "NOLMI_*"-Namen umstellen.

# ─── Modell-Provider ────────────────────────────────────────────────────────
# Default ist Anthropic (Claude Opus 4.7) — matched README-Quick-Start +
# Tech-Stack-Story. OpenAI bleibt als Alternative, auskommentiert.
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL=claude-opus-4-7

# Alternative: OpenAI als Aktiv-Provider. Für Switch hier un-kommentieren,
# unten ACTIVE_PROVIDER=openai setzen und ANTHROPIC_API_KEY entsprechend
# auskommentieren (oder beide gesetzt lassen — gewinnt ACTIVE_PROVIDER).
# OPENAI_API_KEY=sk-replace-me
# OPENAI_MODEL=gpt-5.5

# Aktiver Provider — anthropic | openai | local
ACTIVE_PROVIDER=anthropic

# ─── Runtime-Pfade ──────────────────────────────────────────────────────────
# Alle Pfade sind optional. Leer/ungesetzt → Default vom Workspace-Root aus.
# Relative Werte werden gegen den Workspace-Root aufgelöst (NICHT gegen cwd),
# absolute Werte unverändert genutzt. Hier nur überschreiben, wenn du eine
# zweite Twin-Instanz mit eigenen Files / eigener DB betreibst (z.B. Florian).

# SQLite-Datei. Default: <workspace>/data/twin.db
# TWIN_DATABASE_PATH=

# Persona — Markdown (System-Prompt) + YAML (Name, Handle).
# Default: <workspace>/docs/persona.md  und  <workspace>/docs/persona-meta.yaml
# PERSONA_PATH=
# PERSONA_META_PATH=

# Mandates — YAML mit den erlaubten Capabilities.
# Default: <workspace>/docs/mandates.yaml
# MANDATES_PATH=

# ─── Runtime-Server ─────────────────────────────────────────────────────────
RUNTIME_PORT=4000
RUNTIME_HOST=127.0.0.1

# Web — wird von Next.js gelesen, muss auf den Runtime zeigen.
# WICHTIG: 'localhost' (nicht '127.0.0.1'), weil Browser localhost:3000 und
# 127.0.0.1:3000 als verschiedene Origins behandeln. Cookie wird sonst nicht
# cross-origin mitgesendet → /auth/login klappt, aber /twins kriegt 401.
NEXT_PUBLIC_RUNTIME_URL=http://localhost:4000

# ─── Bridge: Wizard-Default ─────────────────────────────────────────────────
# Für den **normalen Self-Hosting-Pfad** (Onboarding-Wizard im Web-UI) ist
# das die einzige Bridge-Variable, die du brauchst. Sie landet beim Twin-
# Anlegen in twin_profiles.bridge_url. Lokal ungesetzt lassen → Fallback
# http://127.0.0.1:5100. Production: gehostete Bridge, z.B.
# https://bridge.twin.harwayexperience.com.
# NOLMI_DEFAULT_BRIDGE_URL=

# ─── Advanced: File-basierter Twin-Bootstrap (pnpm twin:bootstrap) ──────────
# Die folgenden drei Variablen werden NUR vom Power-User-Pfad
# `pnpm twin:bootstrap` benötigt — File-basierter Twin aus
# docs/persona*.md + ENV, ohne UI. Der normale Self-Hosting-Pfad ist der
# Onboarding-Wizard oben; der braucht diese Variablen NICHT, sondern nur
# NOLMI_DEFAULT_BRIDGE_URL.
#
# Wenn du den Wizard nutzt: diese drei Zeilen ignorieren/leer lassen.
# Wenn du `pnpm twin:bootstrap` nutzen willst: alle drei setzen — der
# Bootstrap wirft sonst mit klarer Diagnose.
BRIDGE_URL=http://127.0.0.1:5100
BRIDGE_TWIN_HANDLE=@markus
BRIDGE_TWIN_TOKEN=

# ─── Bridge-Register-Token (#60) ────────────────────────────────────────────
# Allowlist-Token für POST /twins/register. Caller muss den Wert im Header
# X-Register-Token mitschicken, sonst wird der Call abgelehnt (401).
# Fehlt diese Variable komplett, ist der Endpoint deaktiviert (503) — die
# Bridge läuft weiter, aber kein neuer Twin kann sich registrieren.
# Production: pro Bridge einen langen Random-Token (openssl rand -hex 32).
BRIDGE_REGISTER_TOKEN=local-dev-token

# ─── Encryption (Phase 2.5e) ────────────────────────────────────────────────
# Master-Key für AES-256-GCM-Verschlüsselung der API-Keys in twin_profiles.
# Generieren via: pnpm --filter @nolmi/runtime key:generate
# Niemals in Git committen. Bei Verlust: alle Twins per Re-Bootstrap neu.
NOLMI_ENCRYPTION_KEY=

# ─── Session (Phase 2.5.4) ──────────────────────────────────────────────────
# Secret für iron-session Cookie-Signierung. Mind. 32 Zeichen.
# Generieren via: pnpm --filter @nolmi/runtime session-secret:generate
# Bei Rotation: alle Sessions invalidiert, User loggen sich neu ein.
NOLMI_SESSION_SECRET=

# ─── Session-Cookie-Attribute (2.5.6) ───────────────────────────────────────
# Production: Web auf app.* und Runtime auf runtime.* — Cookie braucht das
# Parent-Domain-Attribut, damit der Browser ihn an beide Subdomains sendet.
# Lokal beide leer lassen → kein Domain-Attribut, kein Secure-Flag (sonst
# lehnt Chrome den Secure-Cookie auf http://localhost ab und Login bricht
# stumm). Backlog: Reverse-Proxy mit Same-Origin macht das überflüssig.
# SESSION_COOKIE_DOMAIN=.twin.harwayexperience.com
# SESSION_COOKIE_SECURE=true

# ─── Episodic-Memory (Phase 3.4) ────────────────────────────────────────────
# Vector-Search-Layer im Send-Path. Defaults sind in 3.4-STRATEGY.md
# festgehalten; pro Twin-Instanz hier überschreibbar.

# Embedding-Provider — local | openai | voyage. Default: local.
# NOLMI_EMBEDDING_PROVIDER=local

# Optional Modell-Override. Default: provider-spezifisch
# (local → Xenova/multilingual-e5-large, openai → text-embedding-3-small,
# voyage → voyage-3).
# NOLMI_EMBEDDING_MODEL=

# Local-Provider Quantisierung — q8 (~560 MB, Default) | fp32 (~2.1 GB).
# NOLMI_EMBEDDING_DTYPE=q8

# Modell-Cache-Pfad für lokales Embedding (multilingual-e5-large q8, ~552 MB)
# Wenn nicht gesetzt: Cache landet in node_modules/.../@huggingface/transformers/.cache/
# Production-Empfehlung: explizit setzen damit Cache Container-Recreates überlebt
# Beispiel: NOLMI_MODEL_CACHE_DIR=/app/data/model-cache
NOLMI_MODEL_CACHE_DIR=

# API-Key generisch (openai/voyage). Fallbacks: OPENAI_API_KEY, VOYAGE_API_KEY.
# NOLMI_EMBEDDING_API_KEY=

# Retrieval-Tunables (3.4.I Hybrid-Search via RRF).
# EPISODIC_TOP_K=3                       # Final Top-K für den System-Prompt
# EPISODIC_MIN_QUERY_LENGTH=10           # Skip-Filter für sehr kurze Sends
# EPISODIC_HYBRID_RRF_K=60               # RRF-Konstante, Industrie-Standard
# EPISODIC_HYBRID_POOL_SIZE=10           # Top-K pro Source (Vector + FTS5)
# EPISODIC_HYBRID_MIN_VECTOR_SIM=0.5     # Pre-RRF Vector-Untergrenze
# EPISODIC_RRF_THRESHOLD=0.015           # Post-RRF Score-Cutoff

# ─── Deployment-Label fürs Frontend ─────────────────────────────────────────
# Wird in den AppFooter inlined (NEXT_PUBLIC_*, also Client-Bundle, deshalb
# Build-Time-Variable im Dockerfile via --build-arg).
# Lokal leer lassen → Default „läuft lokal". In Production auf „production"
# setzen.
# NEXT_PUBLIC_DEPLOYMENT_LABEL=production

# ─── Telegram-Adapter (#130) ────────────────────────────────────────────────
# Local-Dev default: Long-Polling, no public URL needed. Production needs
# webhook mode (false) plus a public HTTPS Runtime-URL.
#
# Auto-detection (#138): if BOTH variables are unset, the runtime falls
# back to TELEGRAM_USE_POLLING=true with a warning log. So a pristine
# clone runs with `pnpm dev` out of the box. For Production: set
# TELEGRAM_USE_POLLING=false AND RUNTIME_PUBLIC_URL explicitly.
TELEGRAM_USE_POLLING=true

# Required when TELEGRAM_USE_POLLING=false. Must be HTTPS, publicly resolvable,
# pointing to the Runtime service. Telegram delivers webhook updates here.
# RUNTIME_PUBLIC_URL=https://runtime.your-domain.com

# ─── Advanced: Autonomer Selbst-Reflexions-Loop (Vision Stufe 2) ────────────
# OPT-IN, Default AUS. Wenn aktiviert, lässt der Twin in einem periodischen
# Background-Loop eine Selbst-Reflexion über SEIN EIGENES Verhalten ('self')
# laufen. Das Ergebnis ist IMMER nur ein PENDING-Eintrag in der Inbox (nie
# autonom wirksam — du approvst/rejectst ihn). Pro Lauf KOSTET das LLM-Tokens
# (ein Call je Twin, der neue Substanz hat und kein offenes Pending). Dedup
# verhindert Doppel-/Trivial-Reflexionen. Power-User-Feature; lass es aus, wenn
# du autonome Token-Kosten nicht willst.
# REFLECTION_LOOP_ENABLED=false
# Intervall in Stunden (Default 24 = täglich). Konservativ halten — nicht klein.
# REFLECTION_LOOP_INTERVAL_HOURS=24
